generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("sales")
  chatworkAccountId String?
  createdAt DateTime  @default(now())
  companies Company[]
  assignedTasks  ProductionTask[] @relation("TaskAssignee")
  requestedTasks ProductionTask[] @relation("TaskRequester")
  updatedTasks   ProductionTask[] @relation("TaskLastUpdatedBy")
  taskComments   TaskComment[]
}

model Company {
  id        String  @id @default(cuid())
  companyId String? @unique
  name      String
  status    String  @default("approaching")
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  contactPerson    String?
  contactPosition  String?
  workplaceCertLevel Int @default(0)
  websiteUrl String?

  // 連絡先
  phone   String?
  address String?

  // 企業情報
  vehicleCount       Int?
  driverCount        Int?
  annualHiringTarget Int?
  adoptionChallenge  String?
  apps               String[]
  dispatchRatio      String?
  shifts             String[]

  // 競合媒体
  competitorMedia       Json?
  tenshokudoCostPerHire Int?

  // 売上管理
  planName     String?
  monthlyFee   Int?
  discountRate Float?
  discountNote String?
  options      Json?

  // 契約期間
  contractStart   DateTime?
  contractRenewal DateTime?
  contractNote  String?  @db.Text

  // 採用実績（累計）
  persona    String[]
  media      String?
  applyCount Int      @default(0)
  hireCount  Int      @default(0)

  // 商談管理
  temperature     String?
  negotiationMemo String?
  nextAction      String?
  nextActionDate  DateTime?

  // メモ
  memo String?

  // ドライバー売上情報
  driverSales Json?

  // 月次実績
  monthlyRecords MonthlyRecord[]

  // 制作案件
  productionTasks ProductionTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyRecord {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  year      Int
  month     Int
  applyCount      Int  @default(0)
  hireCount       Int  @default(0)
  inflowBreakdown Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year, month])
}

model ProductionTask {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  type     String   @default("new")
  priority String   @default("medium")
  status   String   @default("not_started")
  memo     String?  @db.Text
  dueDate     DateTime?
  publishedAt DateTime?
  stoppedAt   DateTime?

  // 制作担当（未割当null可）
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // 依頼営業
  requesterId String?
  requester   User?   @relation("TaskRequester", fields: [requesterId], references: [id])

  // 最終更新者
  lastUpdatedById String?
  lastUpdatedBy   User?   @relation("TaskLastUpdatedBy", fields: [lastUpdatedById], references: [id])

  // コメント
  comments TaskComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskComment {
  id     String         @id @default(cuid())
  taskId String
  task   ProductionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  body     String  @db.Text
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
}