generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("sales")
  roles     String[]  @default([])
  isActive  Boolean   @default(true)
  chatworkAccountId String?
  createdAt DateTime  @default(now())
  companies Company[]
  assignedTasks  ProductionTask[] @relation("TaskAssignee")
  requestedTasks ProductionTask[] @relation("TaskRequester")
  updatedTasks   ProductionTask[] @relation("TaskLastUpdatedBy")
  taskComments   TaskComment[]
}

model Company {
  id        String  @id @default(cuid())
  companyId String? @unique
  name      String
  status    String  @default("approaching")
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  contactPerson    String?
  contactPosition  String?
  workplaceCertLevel Int @default(0)
  websiteUrl String?

  // 連絡先
  phone   String?
  address String?

  // 企業情報
  vehicleCount       Int?
  driverCount        Int?
  annualHiringTarget Int?
  adoptionChallenge  String?
  apps               String[]
  dispatchRatio      String?
  shifts             String[]

  // 競合媒体
  competitorMedia       Json?
  tenshokudoCostPerHire Int?

  // 売上管理
  planName     String?
  monthlyFee   Int?
  discountRate Float?
  discountNote String?
  options      Json?

  // 契約期間
  contractStart   DateTime?
  contractRenewal DateTime?
  contractNote  String?  @db.Text

  // 採用実績（累計）
  persona    String[]
  media      String?
  applyCount Int      @default(0)
  hireCount  Int      @default(0)

  // 商談管理
  temperature     String?
  negotiationMemo String?
  nextAction      String?
  nextActionDate  DateTime?

  // メモ
  memo String?

  // ドライバー売上情報
  driverSales Json?

  // ===== 人材紹介（キャリアアドバイザー向け） =====
  // 紹介契約の有無（手動フラグ）
  hasReferralContract Boolean @default(false)
  // 紹介単価（[{ condition: "〜39歳", amount: 300000 }, ...]）
  referralFees Json?

  // 受け入れ条件（3択: "ok"=可能 / "ng"=不可能 / "consult"=要相談 / null=未入力）
  condWorkSide      String?   // Wワーク・副業
  condFemale        String?   // 女性雇用
  condLgbtq         String?   // LGBTQ受け入れ
  condForeign       String?   // 外国籍雇用
  condSpecialTrain  String?   // 特別講習対応
  condAge64         String?   // 64歳未経験
  condTattoo        String?   // タトゥー・刺青受け入れ
  condAccident      String?   // 事故・違反者受け入れ

  // 受け入れ条件（2択: true/false/null=未入力）
  condDorm          Boolean?  // 寮
  condHousingSupport Boolean? // 住宅支援
  condFemaleFacility Boolean? // 女性専用設備
  condJobChangeLimit Boolean? // 転職回数制限
  condGuarantor      Boolean? // 保証人（true=要 / false=不要）

  // 受け入れ条件（自由記入）
  condAgeRange      String?   // 採用可能年齢
  condRetirementAge String?   // 定年
  condIdealPerson   String?  @db.Text  // 求める人物像
  condHiringStandard String? @db.Text  // 採用基準
  condAppearance    String?  @db.Text  // 身だしなみ
  condMedicalHistory String? @db.Text  // 既往歴
  condNote          String?  @db.Text  // 備考（自由記述）

  // 月次実績
  monthlyRecords MonthlyRecord[]

  // 制作案件
  productionTasks ProductionTask[]

  // 応募明細（マーケ分析用）
  applicationRecords ApplicationRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyRecord {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  year      Int
  month     Int
  applyCount      Int  @default(0)
  hireCount       Int  @default(0)
  inflowBreakdown Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year, month])
}

model ProductionTask {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  type     String   @default("new")
  priority String   @default("medium")
  status   String   @default("not_started")
  memo     String?  @db.Text
  dueDate     DateTime?
  publishedAt DateTime?
  stoppedAt   DateTime?

  // 制作担当（未割当null可）
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // 依頼営業
  requesterId String?
  requester   User?   @relation("TaskRequester", fields: [requesterId], references: [id])

  // 最終更新者
  lastUpdatedById String?
  lastUpdatedBy   User?   @relation("TaskLastUpdatedBy", fields: [lastUpdatedById], references: [id])

  // コメント
  comments TaskComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskComment {
  id     String         @id @default(cuid())
  taskId String
  task   ProductionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  body     String  @db.Text
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
}

model ApplicationRecord {
  id          String   @id @default(cuid())

  sourceCompanyId String
  company     Company? @relation(fields: [companyRef], references: [id])
  companyRef  String?

  appliedAt   DateTime
  year        Int
  month       Int
  status      String
  inflow      String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sourceCompanyId, appliedAt, inflow], name: "uniqueApplication")
  @@index([year, month])
  @@index([inflow])
  @@index([sourceCompanyId])
}

model AdCost {
  id        String   @id @default(cuid())

  // 費用の明細名（例: "プライムサープ(Indeed)", "TELICK", "MATTRZ"）
  name      String

  // 紐づく流入元。overhead（配賦対象外）の場合は null
  inflow    String?

  year      Int
  month     Int

  // direct = 特定流入に紐づく / overhead = 流入に紐づかない全体費
  category  String   @default("direct")

  costType  String   @default("operation")
  unitPrice Int?
  totalCost Int?

  memo      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, year, month], name: "uniqueAdCost")
  @@index([year, month])
  @@index([inflow])
}