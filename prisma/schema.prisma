generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("sales")
  createdAt DateTime  @default(now())
  companies Company[]
}

model Company {
  id        String  @id @default(cuid())
  companyId String? @unique
  name      String
  status    String  @default("approaching")
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  contactPerson    String?
  contactPosition  String?

  // 連絡先
  phone   String?
  address String?

  // 企業情報
  vehicleCount       Int?
  driverCount        Int?
  annualHiringTarget Int?
  adoptionChallenge  String?
  apps               String[]
  dispatchRatio      String?
  shifts             String[]

  // 競合媒体
  competitorMedia       Json?
  tenshokudoCostPerHire Int?

  // 売上管理
  planName     String?
  monthlyFee   Int?
  discountRate Float?
  discountNote String?
  options      Json?

  // 契約期間
  contractStart   DateTime?
  contractRenewal DateTime?
  contractNote  String?  @db.Text

  // 採用実績（累計）
  persona    String[]
  media      String?
  applyCount Int      @default(0)
  hireCount  Int      @default(0)

  // 商談管理
  temperature     String?
  negotiationMemo String?
  nextAction      String?
  nextActionDate  DateTime?

  // メモ
  memo String?

  // ドライバー売上情報
  // 例: {"全体": {"top": 120, "avg": 80}, "隔日勤務": {"top": 100, "avg": 70}, "日勤": {"top": 80, "avg": 60}, "夜勤": {"top": 90, "avg": 65}}
  driverSales Json?

  // 月次実績
  monthlyRecords MonthlyRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyRecord {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  year      Int
  month     Int
  applyCount      Int  @default(0)
  hireCount       Int  @default(0)
  inflowBreakdown Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year, month])
}