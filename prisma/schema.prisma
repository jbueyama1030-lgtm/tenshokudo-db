generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("sales")
  createdAt DateTime  @default(now())
  companies Company[]
}

model Company {
  id            String   @id @default(cuid())
  companyId     String?  @unique  // 企業ID（独自番号）
  name          String            // 会社名
  status        String   @default("approaching") // contracted / approaching / delisted
  userId        String            // 担当者
  user          User     @relation(fields: [userId], references: [id])

  // 採用情報
  persona       String[] // 採用ペルソナ（多選択）例：["20代","30代"]
  media         String?  // 掲載媒体

  // 実績
  applyCount    Int      @default(0) // 転職道経由の応募数
  hireCount     Int      @default(0) // 転職道経由の入社数

  // 連絡先
  phone         String?  // 電話番号
  address       String?  // 住所

  // メモ
  memo          String?  // 備考
// 商談管理
  temperature     String?  // hot / warm / cold
  negotiationMemo String?  // 商談メモ
  nextAction      String?  // 次回アクション
  nextActionDate  DateTime? // 次回アクション日
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}